{
    "name": "nswdpc/governance-arrangements",
    "description": "Service class for parsing governance arrangements data",
    "type": "library",
    "keywords": [
        "nsw-data",
        "nsw",
        "governance",
        "governance arrangements"
    ],
    "license": "BSD-3-Clause",
    "authors": [
        {
            "name": "James Ellis",
            "role": "Developer"
        }
    ],
    "require": {
        "php" : "^8.1",
        "symfony/yaml": ">=6"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3",
        "phpunit/phpunit": "^10 || ^11",
        "phpstan/phpstan": "^2",
        "phpstan/phpstan-phpunit": "^2",
        "rector/rector": "^2",
        "nswdpc/ci-files": "dev-v-4"
    },
    "autoload": {
        "psr-4": {
            "NSWDPC\\GovernanceArrangements\\Services\\": "src/Services/",
            "NSWDPC\\GovernanceArrangements\\Test\\": "tests/"
        }
    },
    "scripts": {
        "phpstan-analyse": "./vendor/bin/phpstan analyse --ansi --no-progress --no-interaction --configuration vendor/nswdpc/ci-files/phpstan/.phpstan.vanilla.neon src/ tests/",
        "rector-dryrun": "./vendor/bin/rector process --dry-run --ansi --config vendor/nswdpc/ci-files/rector/.rector.vanilla.php src/ tests/",
        "rector-process": "./vendor/bin/rector process --no-diffs --ansi --config vendor/nswdpc/ci-files/rector/.rector.vanilla.php src/ tests/",
        "phpcsfixer-fix": "./vendor/bin/php-cs-fixer fix --ansi --no-interaction --config vendor/nswdpc/ci-files/php-cs-fixer/.php-cs-fixer.php src/ tests/"
    }
}
